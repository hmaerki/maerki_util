{
    "backup": {
        "backup_name": "project_xy",
        "directory_target": "/mnt/backup",
        "directory_src": ".",
        "directory_name_include": true,
        "filters": [
            {
                "name": "README.md",
                "logic": "include"
            },
            {
                "path": "project_xy/sub/task.txt",
                "logic": "include"
            },
            {
                "name": ".*\\.md",
                "matching": "regexp"
            },
            {
                "name": ".*\\.txt",
                "matching": "regexp"
            },
            {
                "name": "_git",
                "matching": "nocase",
                "kind": "directory"
            }
        ]
    }
}